{
    "permissions": {
      "defaultMode": "acceptEdits",
      "allow": [
        "Bash(go *)",
        "Bash(gofmt *)",
        "Bash(ls *)",
        "Bash(cat *)",
        "Bash(grep *)",
        "Bash(find *)",
        "Bash(sed *)",
        "Read(**)",
        "Read(/tmp/**)"
      ],
      "ask": [
        "Bash(rm *)",
        "Bash(mv *)"
      ],
      "deny": [
        "Bash(git push *)",
        "Bash(git reset --hard *)"
      ]
    },
    "alwaysThinkingEnabled": false,
    "theme": "dark",
    "migrationVersion": 11
}
