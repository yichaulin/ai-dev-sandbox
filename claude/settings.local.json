{
    "defaultMode": "acceptEdits",
    "permissions": {
      "allow": [
        "Bash(*)",
        "Read(**)",
        "Write(**)",
        "Write(//tmp/**)"
      ],
      "ask": [
        "Bash(rm *)",
        "Bash(mv *)"
      ],
      "deny": [
        "Bash(git push *)",
        "Bash(git reset *)"
      ]
    },
    "alwaysThinkingEnabled": false,
    "theme": "dark",
    "migrationVersion": 11
}
